{
  "--font-heading": "'Oswald', 'Impact', sans-serif",
  "--font-body": "'Source Sans Pro', system-ui, sans-serif",
  "--color-primary": "#c53030",
  "--color-primary-light": "#fc8181",
  "--color-secondary": "#ed8936",
  "--color-accent": "#e53e3e",
