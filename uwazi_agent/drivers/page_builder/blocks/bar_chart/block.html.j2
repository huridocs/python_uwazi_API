{% set data = slots.data %}
{% set explicit_max = slots.max_value | default(none) %}
{% set computed_max = data | map(attribute='value') | map('float') | max %}
{% set max_value = explicit_max if explicit_max is not none else computed_max %}
<section class="bar-chart uwazi-block">
  <div class="bar-chart__inner uwazi-block__inner">
    {% if slots.title %}
    <h3 class="bar-chart__title">{{ slots.title }}</h3>
    {% endif %}
    <div class="bar-chart__list">
      {% for entry in data %}
      {% set value = entry.value | default(0) | float %}
      {% set pct = value | pct(max_value) %}
      <div class="bar-chart__row">
        <div class="bar-chart__label">{{ entry.label }}</div>
        <div class="bar-chart__track">
          <div class="bar-chart__fill" style="background: {{ loop.index0 | chart_color }}; --bar-width: {{ pct }}%;"></div>
        </div>
        <div class="bar-chart__value">{{ entry.value }}{{ slots.unit | default('') }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.bar-chart {
  padding-top: var(--spacing-lg);
  padding-bottom: var(--spacing-lg);
  font-family: var(--font-body);
}
.bar-chart__inner {
  max-width: 700px;
  margin: 0 auto;
}
.bar-chart__title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 var(--spacing-md) 0;
  letter-spacing: -0.01em;
}
.bar-chart__list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.bar-chart__row {
  display: grid;
  grid-template-columns: 140px 1fr 70px;
  align-items: center;
  gap: 0.75rem;
}
@media (max-width: 640px) {
  .bar-chart__row { grid-template-columns: 100px 1fr 50px; gap: 0.5rem; }
}
.bar-chart__label {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bar-chart__track {
  height: 8px;
  background: var(--color-surface);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}
.bar-chart__fill {
  height: 100%;
  width: var(--bar-width, 0%);
  border-radius: 4px;
}
.bar-chart__value {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-text);
  text-align: right;
  font-variant-numeric: tabular-nums;
}
</style>
