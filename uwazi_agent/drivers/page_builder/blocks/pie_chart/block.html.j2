{% set chart_type = slots.chart_type | default('donut') %}
{% set total_value = slots.data | map(attribute='value') | map('float') | sum %}
<section class="pie-chart uwazi-block">
  <div class="pie-chart__inner uwazi-block__inner">
    {% if slots.title %}
    <h3 class="pie-chart__title">{{ slots.title }}</h3>
    {% endif %}
    <div class="pie-chart__body">
      <div class="pie-chart__svg-wrap">
        <svg class="pie-chart__svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(100,100)"{% if chart_type == 'pie' %} class="pie-chart__segments pie-chart__segments--pie"{% else %} class="pie-chart__segments pie-chart__segments--donut"{% endif %}>
            {% set ns = namespace(angle=0.0) %}
            {% for segment in slots.data %}
            {% set seg = segment | default({}) %}
            {% set seg_value = seg.value | default(0) | float %}
            {% if total_value > 0 and seg_value > 0 %}
            {% if chart_type == 'pie' %}
            {% set path_info = seg_value | svg_pie_path(total_value, ns.angle) %}
            {% else %}
            {% set path_info = seg_value | svg_donut_path(total_value, ns.angle) %}
            {% endif %}
            <path d="{{ path_info.d }}" fill="{{ loop.index0 | chart_color }}" class="pie-chart__segment" />
            {% set ns.angle = path_info.end_angle_deg %}
            {% endif %}
            {% endfor %}
          </g>
        </svg>
        {% if chart_type == "donut" and slots.center_label %}
        <div class="pie-chart__center">
          <span class="pie-chart__center-label">{{ slots.center_label }}</span>
          <span class="pie-chart__center-value">{{ total_value | int }}</span>
        </div>
        {% endif %}
      </div>
      <div class="pie-chart__legend">
        {% for segment in slots.data %}
        <div class="pie-chart__legend-item">
          <span class="pie-chart__legend-swatch" style="background: {{ loop.index0 | chart_color }};"></span>
          <span class="pie-chart__legend-label">{{ segment.label }}</span>
          <span class="pie-chart__legend-value">{{ segment.value }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
.pie-chart {
  padding-top: var(--spacing-lg);
  padding-bottom: var(--spacing-lg);
  font-family: var(--font-body);
}
.pie-chart__inner {
  max-width: 600px;
  margin: 0 auto;
}
.pie-chart__title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 var(--spacing-md) 0;
  letter-spacing: -0.01em;
}
.pie-chart__body {
  display: flex;
  align-items: center;
  gap: var(--spacing-xl);
}
@media (max-width: 640px) {
  .pie-chart__body { flex-direction: column; gap: var(--spacing-lg); }
}
.pie-chart__svg-wrap {
  position: relative;
  flex-shrink: 0;
  width: 200px;
  height: 200px;
}
.pie-chart__svg {
  width: 100%;
  height: 100%;
  display: block;
  transform: rotate(-90deg);
}
.pie-chart__segments--donut .pie-chart__segment {
  transform-origin: center;
}
.pie-chart__segment {
  transition: opacity 0.2s ease;
  stroke: var(--color-bg);
  stroke-width: 2;
  cursor: default;
}
.pie-chart__segment:hover {
  opacity: 0.8;
}
.pie-chart__center {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.pie-chart__center-label {
  font-size: 0.65rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-text-muted);
}
.pie-chart__center-value {
  font-family: var(--font-heading);
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.1;
  margin-top: 0.15rem;
}
.pie-chart__legend {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  flex: 1;
  min-width: 0;
}
.pie-chart__legend-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.85rem;
}
.pie-chart__legend-swatch {
  width: 10px;
  height: 10px;
  border-radius: 2px;
  flex-shrink: 0;
}
.pie-chart__legend-label {
  color: var(--color-text);
  font-weight: 500;
  flex: 1;
  min-width: 0;
}
.pie-chart__legend-value {
  color: var(--color-text-muted);
  font-variant-numeric: tabular-nums;
  font-weight: 500;
}
</style>
