<section class="event-chart-v">
  <div class="event-chart-v__inner">
    {% if slots.title %}
    <h3 class="event-chart-v__title">{{ slots.title }}</h3>
    {% endif %}
    <div class="event-chart-v__track">
      <div class="event-chart-v__line"></div>
      <div class="event-chart-v__events">
        {% for event in slots.events %}
        <div class="event-chart-v__event">
          <div class="event-chart-v__bubble">
            <div class="event-chart-v__bubble-dot"></div>
            <div class="event-chart-v__bubble-ring"></div>
          </div>
          <div class="event-chart-v__card">
            <span class="event-chart-v__date">{{ event.date }}</span>
            <h4 class="event-chart-v__event-title">{{ event.title }}</h4>
            {% if event.description %}
            <p class="event-chart-v__event-desc">{{ event.description }}</p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
.event-chart-v {
  padding: var(--spacing-lg) var(--spacing-md);
  font-family: var(--font-body);
}
.event-chart-v__inner {
  max-width: 800px;
  margin: 0 auto;
}
.event-chart-v__title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 var(--spacing-lg) 0;
  letter-spacing: -0.01em;
  text-align: center;
}

.event-chart-v__track {
  position: relative;
  padding: 0;
}
.event-chart-v__line {
  position: absolute;
  left: 9px;
  top: 8px;
  bottom: 8px;
  width: 2px;
  background: var(--color-border);
  border-radius: 1px;
}
@media (min-width: 768px) {
  .event-chart-v__line {
    left: 19px;
  }
}

.event-chart-v__events {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.event-chart-v__event {
  position: relative;
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: var(--spacing-sm);
  align-items: flex-start;
}
@media (min-width: 768px) {
  .event-chart-v__event {
    grid-template-columns: 60px 1fr;
    gap: var(--spacing-md);
  }
}

.event-chart-v__bubble {
  position: relative;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  flex-shrink: 0;
}
@media (min-width: 768px) {
  .event-chart-v__bubble {
    width: 40px;
    height: 20px;
  }
}
.event-chart-v__bubble-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-primary);
  box-shadow: 0 0 0 4px var(--color-bg);
  transition: transform 0.3s, background 0.3s;
}
.event-chart-v__bubble-ring {
  position: absolute;
  inset: 0;
  margin: auto;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1px solid var(--color-primary);
  opacity: 0;
  transition: opacity 0.3s, transform 0.3s;
}
.event-chart-v__event:hover .event-chart-v__bubble-dot {
  transform: scale(1.25);
  background: var(--color-accent);
}
.event-chart-v__event:hover .event-chart-v__bubble-ring {
  opacity: 0.5;
  transform: scale(1.3);
}

.event-chart-v__card {
  min-width: 0;
}
.event-chart-v__date {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-primary);
  margin-bottom: 0.2rem;
}
.event-chart-v__event-title {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 0.2rem 0;
  line-height: 1.35;
  letter-spacing: -0.01em;
}
.event-chart-v__event-desc {
  font-family: var(--font-body);
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--color-text-muted);
  margin: 0;
}
</style>
