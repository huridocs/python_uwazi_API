{% set h = {"small": "22.5vh", "medium": "30vh", "large": "48.75vh"}[slots.height] %}
<section class="hero uwazi-block uwazi-block--full-bleed" style="--hero-height: {{ h }};">
  <div class="hero__backdrop" aria-hidden="true"></div>
  <div class="hero__inner uwazi-block__inner">
    {% if slots.category_label %}
    <span class="hero__label">{{ slots.category_label }}</span>
    {% endif %}
    <h1 class="hero__title">{{ slots.title }}</h1>
    {% if slots.subtitle %}
    <p class="hero__subtitle">{{ slots.subtitle }}</p>
    {% endif %}
  </div>
</section>

<style>
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: var(--hero-height, 30vh);
  padding: var(--spacing-lg) 0;
  background: var(--gradient-hero);
  overflow: hidden;
}

.hero__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.15);
  z-index: 1;
}

.hero__inner {
  position: relative;
  z-index: 2;
}

.hero__label {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: var(--spacing-xs);
}

.hero__title {
  font-family: var(--font-heading);
  font-size: clamp(3.05rem, 5.75vw, 4.55rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: #ffffff;
  max-width: 900px;
  text-wrap: balance;
}

.hero__subtitle {
  font-family: var(--font-body);
  font-size: 1.15rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
  margin-top: var(--spacing-sm);
  max-width: 600px;
  font-weight: 400;
}
</style>
